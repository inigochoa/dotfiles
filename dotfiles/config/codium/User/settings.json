{
    "claudeCode.preferredLocation": "panel",
    "codesnap.shutterAction": "copy",
    "editor.fontFamily": "JetBrains Mono",
    "editor.fontLigatures": true,
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        "*.csproj": "*.config, *proj.user, appsettings.*, bundleconfig.json",
        "*.css": "${capture}.min.css, ${capture}.css.map, ${capture}.module.css, ${capture}.scss",
        "*.go": "${capture}_test.go",
        "*.html": "${capture}.css, ${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts, ${capture}.test.js, ${capture}.spec.js, ${capture}.jsx",
        "*.scss": "${capture}.css, ${capture}.css.map, ${capture}.module.scss",
        "*.ts": "${capture}.js, ${capture}.d.ts, ${capture}.js.map, ${capture}.test.ts, ${capture}.spec.ts, ${capture}.tsx",
        "*.sln": "*.csproj, *.config",
        "*.yaml": "${capture}.yml",
        ".editorconfig": ".prettierrc, .prettierignore, .eslintrc.*, .stylelintrc.*",
        ".env": ".env.*",
        ".gitignore": ".gitattributes, .gitmodules, .gitmessage, .gitconfig, .git/",
        "composer.json": "composer.lock, composer.phar, vendor/, composer.yaml, symfony.lock",
        "Dockerfile": "docker-compose.yml, .dockerignore, docker/",
        "Makefile": "*.mk, makefile*",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, node_modules/, .npmrc, .yarnrc, .nvmrc",
        "README.md": "LICENSE, CHANGELOG.md, CONTRIBUTING.md, CODE_OF_CONDUCT.md, AUTHORS, CONTRIBUTORS",
        "tsconfig.json": "tsconfig.*.json",
    },
    "files.associations": {
        "*.actions": "makefile",
        "tpl.plugins": "json",
    },
    "git.confirmSync": false,
    "git.suggestSmartCommit": false,
    "json.schemaDownload.trustedDomains": {
        "https://schemastore.azurewebsites.net/": true,
        "https://raw.githubusercontent.com/microsoft/vscode/": true,
        "https://raw.githubusercontent.com/devcontainers/spec/": true,
        "https://www.schemastore.org/": true,
        "https://json.schemastore.org/": true,
        "https://json-schema.org/": true,
        "https://developer.microsoft.com/json-schemas/": true,
        "https://opencode.ai": true,
        "https://models.dev": true
    },
    "[markdown]": {
        "editor.rulers": [80]
    },
    "projectManager.openInNewWindowWhenClickingInStatusBar": true,
    "projectManager.tags": [],
    "terminal.integrated.fontFamily": "FiraCode Nerd Font Mono",
    "terminal.integrated.fontLigatures.enabled": true,
    "window.newWindowProfile": "Default",
    "workbench.colorTheme": "One Dark Pro Darker",
    "workbench.iconTheme": "symbols",
    "workbench.productIconTheme": "fluent-icons",
    "workbench.startupEditor": "none",
}
