# ~/.bashrc.d/07-node

## fnm - https://github.com/Schniz/fnm
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --use-on-cd --shell bash)"
fi

## Tools
if command -v pnpm >/dev/null 2>&1; then
  alias bench="pnpx autocannon --latency --renderStatusCodes"
  alias benchhard="bench --connections 200 --duration 60"
  alias card="pnpx @inigochoa/card"
  alias ghgrab="pnpx @ghgrab/ghgrab"
  alias npkill="pnpx npkill ."
  alias pages="pnpx gh-pages --branch pages --dist dist --dotfiles --no-history"
  alias present="pnpx reveal-md"
  alias revealmd="pnpx reveal-md"
  alias serve="pnpx serve"
  alias lighthouse="pnpx unlighthouse --no-cache --site"
fi

## nvm - https://github.com/nvm-sh/nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

## pnpm - https://pnpm.io/es/
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
